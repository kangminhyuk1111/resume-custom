<div class="project">
  <h3 class="project-title">
    {{title}}
    {{#if type}}<span class="project-type {{type}}">{{type_label}}</span>{{/if}}
    {{#if links.length}}
    <span class="project-title-links">
      {{#each links}}
      <a href="{{href}}" class="project-title-link"{{#if id}} id="{{id}}"{{/if}} target="_blank">
        {{#if (eq icon "globe")}}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>{{/if}}
        {{#if (eq icon "instagram")}}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>{{/if}}
        {{#if (eq icon "github")}}<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>{{/if}}
        {{#if (eq icon "pencil")}}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>{{/if}}
        {{label}}
      </a>
      {{/each}}
    </span>
    {{/if}}
  </h3>

  {{#each blocks}}
    {{#if (eq type "arch-diagram")}}{{> block-arch-diagram this}}{{/if}}
    {{#if (eq type "metrics")}}{{> block-metrics this}}{{/if}}
    {{#if (eq type "step")}}{{> block-step this}}{{/if}}
    {{#if (eq type "problem")}}{{> block-problem this}}{{/if}}
    {{#if (eq type "reflection")}}{{> block-reflection this}}{{/if}}
  {{/each}}
</div>
