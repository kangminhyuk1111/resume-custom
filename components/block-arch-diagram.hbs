<div class="arch-diagram">
{{#if wrap_inner}}
  <div style="display:flex;align-items:center;justify-content:center;gap:0;">
    {{#each nodes}}
    {{#unless @first}}<div class="arch-arrow">{{#if (eq ../arrow_style "small")}}<svg viewBox="0 0 30 20" fill="none"><path d="M0 10h22m0 0l-5-4m5 4l-5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>{{else}}<svg viewBox="0 0 36 20" fill="none"><path d="M0 10h28m0 0l-6-5m6 5l-6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>{{/if}}</div>{{/unless}}
    <div class="arch-node"><div class="arch-box {{kind}}"><div class="arch-box-label">{{label}}</div><div class="arch-box-sub">{{sub}}</div>{{#if metric}}<div class="arch-box-metric">{{metric}}</div>{{/if}}</div></div>
    {{/each}}
  </div>
{{else}}
  {{#each nodes}}
  {{#unless @first}}
  <div class="arch-arrow">
    {{#if (eq ../arrow_style "small")}}<svg viewBox="0 0 30 20" fill="none"><path d="M0 10h22m0 0l-5-4m5 4l-5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>{{else}}<svg viewBox="0 0 36 20" fill="none"><path d="M0 10h28m0 0l-6-5m6 5l-6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>{{/if}}
  </div>
  {{/unless}}
  <div class="arch-node">
    <div class="arch-box {{kind}}">
      <div class="arch-box-label">{{label}}</div>
      <div class="arch-box-sub">{{sub}}</div>
      {{#if metric}}<div class="arch-box-metric">{{metric}}</div>{{/if}}
    </div>
  </div>
  {{/each}}
{{/if}}
</div>
